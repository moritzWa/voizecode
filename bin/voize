#!/usr/bin/env bash
# `voize` — production mode: start the laptop agent against the DEPLOYED relay and print the
# phone URL. Type `voize` in any repo → a chat opens for that directory, reachable from the
# phone on cellular at the printed link. For the local dev stack (Electron/localhost) use
# `voize-dev`. Overridable: VOIZE_RELAY_URL / VOIZE_APP_URL / VOIZE_TOKEN.
VOIZE_DIR="${VOIZE_DIR:-$HOME/CODE/voizecode}"
TARGET="$PWD"

RELAY="${VOIZE_RELAY_URL:-wss://voizecode-relay.moritzwa.deno.net}"
APP="${VOIZE_APP_URL:-https://voizecode-web.moritzwa.deno.net}"
TOKEN="${VOIZE_TOKEN:-$(cat "$HOME/.voizecode/token" 2>/dev/null)}"

if pgrep -f "laptop/voizecode.mjs" >/dev/null 2>&1; then
  # Agent already up — add a chat tab for this directory (routes through the deployed relay).
  VOIZE_RELAY_URL="$RELAY" VOIZE_TOKEN="$TOKEN" node "$VOIZE_DIR/bin/new-chat.mjs" "$TARGET" || true
else
  # Fresh start: launch the agent IN this directory — its first chat opens here automatically.
  # caffeinate -is keeps the Mac awake (idle + system sleep) for exactly as long as the agent
  # runs, so the phone can keep talking to it unattended. Lid must stay open (clamshell sleep
  # is not preventable without an external display).
  echo "voize: starting agent → $RELAY  (keeping Mac awake while it runs)"
  ( cd "$TARGET" && VOIZE_RELAY_URL="$RELAY" VOIZE_APP_URL="$APP" \
      nohup caffeinate -is node "$VOIZE_DIR/laptop/voizecode.mjs" >/tmp/voizecode-agent.log 2>&1 & )
fi

echo "voize → $APP/?key=$TOKEN  (chat: $(basename "$TARGET"))"
