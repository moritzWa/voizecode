# Relay (copy to relay/.env or export before `deno task dev`)
DEEPGRAM_API_KEY=     # STT (streaming) + TTS (Aura-2). Empty = voice input off, typed text still works.
OPENAI_API_KEY=       # narration summarizer + TTS fallback. Empty narration = speaks raw reply.
VOIZE_NARRATE_MODEL=gpt-4.1-nano  # summarizer model (uses OpenAI key). Empty model = speaks raw reply.
VOIZE_TTS=openai              # TTS provider: openai (streams mp3, default) | deepgram (whole-blob)
VOIZE_TTS_VOICE=aura-2-thalia-en  # Deepgram Aura-2 voice (only used when VOIZE_TTS=deepgram)
VOIZE_SPEED=1.8       # (legacy) OpenAI non-stream speed; live speed is the client playback slider
VOIZE_UTTER_GAP_MS=1600       # silence (ms) that ends a spoken utterance
VOIZE_RELAY_PORT=8787

# Laptop CLI (voizecode.mjs)
VOIZE_MODEL=sonnet            # claude model: sonnet | opus | haiku
VOIZE_RELAY_URL=ws://localhost:8787
VOIZE_RECONNECT_CAP_MS=15000  # max wait between reconnect attempts (retries forever)

# Client (client/.env.local)
NEXT_PUBLIC_RELAY_WS=ws://localhost:8787
NEXT_PUBLIC_RECONNECT_CAP_MS=15000  # max wait between reconnect attempts (online event reconnects instantly)
