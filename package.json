{
  "name": "voizecode",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n relay,client -c magenta,cyan \"npm:dev:relay\" \"npm:dev:client\"",
    "dev:relay": "cd relay && deno task dev",
    "dev:client": "cd client && npm run dev",
    "agent": "cd laptop && node voizecode.mjs",
    "setup": "cd laptop && npm install && cd ../client && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
