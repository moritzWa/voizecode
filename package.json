{
  "name": "voizecode",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n relay,client,agent -c magenta,cyan,green \"npm:dev:relay\" \"npm:dev:client\" \"npm:dev:agent\"",
    "dev:relay": "cd relay && deno task dev",
    "dev:client": "cd client && npm run dev",
    "dev:agent": "node --watch laptop/voizecode.mjs",
    "app": "cd electron && npm run dev",
    "agent": "cd laptop && node voizecode.mjs",
    "setup": "cd laptop && npm install && cd ../client && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
